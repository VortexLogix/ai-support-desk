<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Add private Azure Artifacts feed below if required -->
    <!-- <add key="AiSupportDesk-Feed" value="https://pkgs.dev.azure.com/{org}/{project}/_packaging/{feedName}/nuget/v3/index.json" /> -->
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
